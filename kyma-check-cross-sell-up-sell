async function getProductsInProductGroup(scv2, auth, productGroupId) {
  const fullURL = `${scv2}product-service/products?$filter=productGroupDisplayId eq '${productGroupId}'`;

  let config = {
    method: 'get',
    maxBodyLength: Infinity,
    url: fullURL,
    headers: {
      'Authorization': auth
    }
  };

  try {
    const response = await axios(config);
    return response.data;
  } catch (error) {
    console.error('Error fetching products in product group:', error);
    throw error;
  }
}

async function getOAuth2Token(clientId, clientSecret, tokenEndpoint) {
  const params = new URLSearchParams({
    grant_type: 'client_credentials',
    client_id: clientId,
    client_secret: clientSecret,
  });

  try {
    const response = await axios.post(tokenEndpoint, params, {
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
      },
    });
    console.log('START PROCESSING.');
    console.log('1) OAuth Token successfully fetched.');
    return response.data.access_token;

  } catch (error) {
    console.error('Error obtaining OAuth 2.0 token:', error.response ? error.response.data : error.message);
    throw error;
  }
}

async function getAIRecommendations(inputLineItems, allRelevantProducts, token) {
  const fullURL = 'https://cpi-ptf-011-6bmz1yku.it-cpi018-rt.cfapps.eu10-003.hana.ondemand.com/http/create/prompt/chatgpt';

  const prompt = `
  I have the following items ${inputLineItems} in my relevant product category.

  I have the following products: ${allRelevantProducts}.

  Please check if cross sell / up sell makes sense.
  Please answer with the best fit only.
  Please answer in JSON format only. Relevant properties are:
  - productId
  - a really short explanation why this is the best fit in regards to the other products.
  `;

  var combinedJson = {
    content: prompt
  };

  const cleanedPrompt = convertJsonToReadableString(combinedJson);

  const res = await axios.get(fullURL, {
    headers: {
      'Content-Type': 'application/json',

      Authorization: `Bearer ${token}`,
    },
    data: cleanedPrompt
  });
  console.log('2) AI Recommendations succesfully fetched.');
  let result = res.data.choices[0].message.content;
  return result;
}

function convertJsonToReadableString(jsonObject) {
  return JSON.stringify(jsonObject, (key, value) => {
      // Replace double quotes with single quotes
      if (typeof value === 'string') {
        return value.replace(/"/g, "'");
      }
      return value;
    }, 2) // Pretty print the JSON with indentation
    .replace(/\\n/g, ' ') // Remove newlines (if any)
    .replace(/\\\\"/g, "'"); // Remove escaped double quotes
}

